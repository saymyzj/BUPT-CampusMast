# -----------------------------------------------------------------------------
# 文件说明：
# 这是 Docker 构建忽略文件，用于减少镜像构建上下文体积，避免把依赖目录、缓存、
# 本地环境文件和构建产物打进镜像上下文。
# -----------------------------------------------------------------------------

.git
.idea
.vscode
frontend/node_modules
frontend/dist
backend/.venv
backend/venv
__pycache__
*.pyc
.DS_Store
.env
frontend/.env
backend/.env

