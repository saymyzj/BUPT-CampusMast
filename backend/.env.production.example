# -----------------------------------------------------------------------------
# 文件说明：
# 这是后端生产环境变量模板，供单机 Linux 服务器或容器部署时使用。
# 默认假设前端通过 Nginx 暴露在 80/443，后端仅在内网服务名或容器网络中可访问。
# -----------------------------------------------------------------------------

APP_NAME=CampusMast API
APP_ENV=production
APP_DEBUG=false
API_PREFIX=/api

CORS_ORIGINS=https://your-domain.example,http://your-server-ip

DATABASE_URL=mysql+pymysql://campusmast:strong-password@mysql:3306/campusmast
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=campusmast-prod
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me
OSS_BASE_URL=https://cdn.your-domain.example

DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com

