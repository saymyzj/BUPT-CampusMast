# -----------------------------------------------------------------------------
# 文件说明：
# 这是后端环境变量模板，覆盖数据库、Redis、JWT、OSS、DeepSeek 等基础配置。
# 组长后续可以在部署阶段继续补充生产环境变量，但开发阶段应统一从这里拷贝。
# -----------------------------------------------------------------------------

APP_NAME=CampusMast API
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=mysql+pymysql://campusmast:campusmast@127.0.0.1:3306/campusmast
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_BUCKET_NAME=campusmast-dev
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me
OSS_BASE_URL=https://cdn.example.com

DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
