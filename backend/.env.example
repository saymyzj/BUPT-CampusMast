# -----------------------------------------------------------------------------
# 文件说明：
# 这是本地验收版后端环境变量模板，覆盖数据库、Redis、JWT、本地上传、
# DeepSeek 等基础配置。复制成 .env 后即可在本机运行。
# -----------------------------------------------------------------------------

APP_NAME=CampusMast API
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DATABASE_URL=mysql+pymysql://campusmast:campusmast@127.0.0.1:3306/campusmast
REDIS_URL=redis://127.0.0.1:6379/0

JWT_SECRET=change-me-for-local-test
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
WEBSOCKET_TOKEN_EXPIRE_MINUTES=15

SEED_ADMIN_EMAIL=admin@bupt.edu.cn
SEED_ADMIN_PASSWORD=Admin123456
SEED_ADMIN_NICKNAME=CampusMast 管理员
SEED_DEMO_USER_EMAIL=demo.user@bupt.edu.cn
SEED_DEMO_USER_PASSWORD=Demo123456
SEED_DEMO_USER_NICKNAME=演示用户

LOCAL_UPLOAD_DIR=uploads
LOCAL_UPLOAD_BASE_URL=/uploads
LOCAL_UPLOAD_MAX_SIZE_MB=5

DEEPSEEK_API_KEY=replace-me
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TIMEOUT_SECONDS=20
